PORT=5000
NODE_ENV=development

MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/safelayers?retryWrites=true&w=majority

JWT_SECRET=replace_with_a_long_random_access_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d
JWT_PREAUTH_EXPIRES_IN=5m

TOTP_ENCRYPTION_KEY=replace_with_a_long_random_totp_encryption_key
BCRYPT_ROUNDS=12
ADMIN_SETUP_KEY=replace_with_a_private_admin_setup_key

FRONTEND_URL=http://localhost:3000

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
TRANSFER_RATE_LIMIT_MAX=10
